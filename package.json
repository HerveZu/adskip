{
    "name": "adskip",
    "private": true,
    "description": "Detect and skip in-video sponsor reads on YouTube using captions + an LLM",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"vite build --watch\" \"node scripts/content-scripts.mjs --watch\" \"vite build --watch --config vite.config.inject.ts\"",
        "build": "tsc -b && vite build && vite build --config vite.config.inject.ts && node scripts/content-scripts.mjs",
        "typecheck": "tsc -b",
        "lint": "eslint .",
        "format": "prettier --write \"./src/**/*.{ts,tsx}\""
    },
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/chrome": "^0.0.287",
        "@types/node": "^22.13.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "concurrently": "^9.1.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.5.0",
        "prettier": "^3.4.0",
        "typescript": "^5.8.0",
        "typescript-eslint": "^8.59.1",
        "vite": "^6.2.0",
        "vite-plugin-static-copy": "^2.2.0"
    },
    "dependencies": {
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-tabs": "^1.1.13",
        "@tailwindcss/vite": "^4.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "lucide-react": "^1.14.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.0.0"
    }
}
